DATABASE_URL="file:./dev.db"

# Vimeo authenticated archive ingest
# Create a Vimeo personal access token with permission to read your account's private videos and text tracks.
# Never commit your real .env file or token.
VIMEO_ACCESS_TOKEN=
VIMEO_USER_ID=
VIMEO_ACCOUNT_URI=
VIMEO_SYNC_ON_START=false
VIMEO_SYNC_LIMIT=
VIMEO_FORCE_REFRESH=false
