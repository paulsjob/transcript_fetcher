DATABASE_URL="file:./dev.db"
VIMEO_CHANNEL_URL="https://vimeo.com/channels/your-channel-name"

# Editorial analysis config
ANALYSIS_PROVIDER="extractive" # options: extractive | openai
ANALYSIS_MODEL="gpt-4.1-mini"
ANALYSIS_VERSION="v2-editorial"
ANALYSIS_MIN_WORD_COUNT="120"
ANALYSIS_MIN_SEGMENT_COUNT="6"
ANALYSIS_MIN_DURATION_SECONDS="90"

# Required when ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
