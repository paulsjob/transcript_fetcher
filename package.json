{
  "name": "transcript_fetcher",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "npm run prisma:sync && nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run prisma:sync && node server/index.js",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate",
    "prisma:db:push": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma db push",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma migrate dev --name vimeo_archive_foundation",
    "prisma:sync": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma db push && DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate",
    "postinstall": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vimeo/player": "^2.29.5",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10",
    "prisma": "^5.22.0"
  }
}
